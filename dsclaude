#!/usr/bin/env bash
# dsclaude — launch Claude Code on DeepSeek's Anthropic-compatible API.
#
# Follows the official guide:
#   https://api-docs.deepseek.com/guides/anthropic_api
#   https://api-docs.deepseek.com/guides/coding_agents
#
# Reads DEEPSEEK_API_KEY from the environment first, then falls back to
# ~/.zshrc / ~/.bashrc / ~/.bash_profile / ~/.profile if not already exported.
#
# Quick start (no install needed):
#   chmod +x dsclaude
#   ./dsclaude
#
# Optional — make it globally available:
#   sudo mv dsclaude /usr/local/bin/ && sudo chmod +x /usr/local/bin/dsclaude
#
# Use:
#   dsclaude                  # start on deepseek-v4-pro  (default, full reasoning)
#   dsclaude fast             # start on deepseek-v4-flash[1m] (cheaper / faster)
#   dsclaude long             # request a 1M context window (DeepSeek V4 long-context)
#   dsclaude long fast        # 1M + flash
#   dsclaude update           # git pull latest from the dsclaude repo
#   dsclaude --help           # any remaining flag is forwarded to claude
#
# Backward-compat aliases (kept for older muscle memory — v4-pro is unified
# thinking/non-thinking, so these all resolve to deepseek-v4-pro today):
#   think | reasoner | -r     # same as default
#
# Optional env overrides (take precedence over the positional aliases):
#   DSCLAUDE_CTX=1048576      # set CLAUDE_CODE_MAX_CONTEXT_TOKENS and DISABLE_COMPACT=1
#   DSCLAUDE_OUTPUT=8000      # cap output tokens via CLAUDE_CODE_MAX_OUTPUT_TOKENS
#   DSCLAUDE_EFFORT=max       # CLAUDE_CODE_EFFORT_LEVEL (default: max, per DeepSeek docs)
#
# In-session switch:
#   /model deepseek-v4-flash[1m]  # switch to the fast/haiku tier
#   /model deepseek-v4-pro[1m]    # switch back to pro
#
set -euo pipefail

self_dir="$(cd "$(dirname "$0")" && pwd)"

dsclaude_update() {
  local repo=""
  # 1) We're inside the repo checkout (most common).
  local self_dir
  self_dir="$(cd "$(dirname "$0")" && pwd)"
  if [ -d "$self_dir/.git" ]; then
    repo="$self_dir"
  fi
  # 2) DSCLAUDE_HOME env var.
  if [ -z "$repo" ] && [ -n "${DSCLAUDE_HOME:-}" ]; then
    repo="$DSCLAUDE_HOME"
  fi
  # 3) Common clone location.
  if [ -z "$repo" ] && [ -d "$HOME/github/dsclaude/.git" ]; then
    repo="$HOME/github/dsclaude"
  fi
  if [ -z "$repo" ]; then
    echo "dsclaude: cannot find the dsclaude repo for self-update." >&2
    echo "  Set DSCLAUDE_HOME=/path/to/dsclaude  or  cd into the repo and run ./dsclaude update" >&2
    exit 1
  fi
  echo "dsclaude: pulling latest from $repo ..."
  git -C "$repo" pull && echo "dsclaude: updated." || {
    echo "dsclaude: git pull failed. Check network or resolve conflicts manually." >&2
    exit 1
  }
  exit 0
}

extract_key_from_file() {
  local file="$1"
  [ -f "$file" ] || return 1
  grep -E '^[[:space:]]*(export[[:space:]]+)?DEEPSEEK_API_KEY=' "$file" \
    | tail -n1 \
    | sed -E 's/^[[:space:]]*(export[[:space:]]+)?DEEPSEEK_API_KEY=//' \
    | sed -E 's/^"(.*)"$/\1/; s/^'"'"'(.*)'"'"'$/\1/'
}

API_KEY="${DEEPSEEK_API_KEY:-}"
if [ -z "$API_KEY" ]; then
  for f in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile"; do
    candidate="$(extract_key_from_file "$f" || true)"
    if [ -n "${candidate:-}" ]; then
      API_KEY="$candidate"
      break
    fi
  done
fi

if [ -z "$API_KEY" ]; then
  echo "❌ DEEPSEEK_API_KEY not found." >&2
  echo "   Add one line to ~/.zshrc or ~/.bashrc:" >&2
  echo "     export DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxx" >&2
  exit 1
fi

# DeepSeek V4 model names (per DeepSeek docs, 2026-04).
PRO_MODEL="deepseek-v4-pro[1m]"
FLASH_MODEL="deepseek-v4-flash[1m]"

# Positional aliases: `long` (1M context) and `fast` (flash as main).
LONG_CTX=0
MAIN_MODEL="$PRO_MODEL"
HAIKU_MODEL="$FLASH_MODEL"

while [ $# -gt 0 ]; do
  case "$1" in
    update)
      dsclaude_update
      ;;
    long)
      LONG_CTX=1
      shift
      ;;
    fast|flash)
      MAIN_MODEL="$FLASH_MODEL"
      shift
      ;;
    think|reasoner|-r)
      # Backward compat — v4-pro handles both thinking and non-thinking.
      MAIN_MODEL="$PRO_MODEL"
      shift
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

# Pick the "other" model to surface in Claude Code's /model picker so you can
# switch mid-session without restarting.
if [ "$MAIN_MODEL" = "$PRO_MODEL" ]; then
  OTHER_MODEL="$FLASH_MODEL"
  OTHER_DESC="DeepSeek V4 Flash — fast / cheap haiku tier"
else
  OTHER_MODEL="$PRO_MODEL"
  OTHER_DESC="DeepSeek V4 Pro — full reasoning"
fi

# Start local proxy to fix DeepSeek's metadata.user_id validation.
# Claude Code sends a hashed user_id that may contain base64 chars (+, /, =)
# which DeepSeek rejects with 400. The proxy sanitizes it to [a-zA-Z0-9_-].
# https://github.com/Agents365-ai/dsclaude/issues/5
PROXY_SCRIPT="$self_dir/dsclaude-proxy.mjs"
PROXY_PID=""
PROXY_PORT="${DSCLAUDE_PROXY_PORT:-19876}"

cleanup_proxy() {
  if [ -n "$PROXY_PID" ] && kill -0 "$PROXY_PID" 2>/dev/null; then
    kill "$PROXY_PID" 2>/dev/null
    wait "$PROXY_PID" 2>/dev/null || true
  fi
}
trap cleanup_proxy EXIT

if [ -f "$PROXY_SCRIPT" ]; then
  node "$PROXY_SCRIPT" &>/dev/null &
  PROXY_PID=$!
  # Wait for proxy to be ready
  for _ in $(seq 1 30); do
    if kill -0 "$PROXY_PID" 2>/dev/null && nc -z 127.0.0.1 "$PROXY_PORT" 2>/dev/null; then
      break
    fi
    sleep 0.1
  done
  export ANTHROPIC_BASE_URL="http://127.0.0.1:${PROXY_PORT}/anthropic"
else
  export ANTHROPIC_BASE_URL="https://api.deepseek.com/anthropic"
fi

export ANTHROPIC_AUTH_TOKEN="$API_KEY"
export API_TIMEOUT_MS="600000"
export ANTHROPIC_MODEL="$MAIN_MODEL"
export ANTHROPIC_DEFAULT_OPUS_MODEL="$MAIN_MODEL"
export ANTHROPIC_DEFAULT_SONNET_MODEL="$MAIN_MODEL"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="$HAIKU_MODEL"
export CLAUDE_CODE_SUBAGENT_MODEL="$FLASH_MODEL"
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
export CLAUDE_CODE_DISABLE_NONSTREAMING_FALLBACK=1
export CLAUDE_CODE_EFFORT_LEVEL="${DSCLAUDE_EFFORT:-max}"

# Expose the other DeepSeek model inside the `/model` picker.
export ANTHROPIC_CUSTOM_MODEL_OPTION="$OTHER_MODEL"
export ANTHROPIC_CUSTOM_MODEL_OPTION_NAME="$OTHER_MODEL"
export ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION="$OTHER_DESC"

# Optional context-window override. Env > positional > unset (Claude Code default).
# DeepSeek V4 Pro supports up to 1,048,576 input tokens.
CTX="${DSCLAUDE_CTX:-}"
if [ -z "$CTX" ] && [ "$LONG_CTX" = "1" ]; then
  CTX="1048576"
fi
if [ -n "$CTX" ]; then
  export CLAUDE_CODE_MAX_CONTEXT_TOKENS="$CTX"
  export DISABLE_COMPACT=1
fi

# Optional output cap.
if [ -n "${DSCLAUDE_OUTPUT:-}" ]; then
  export CLAUDE_CODE_MAX_OUTPUT_TOKENS="$DSCLAUDE_OUTPUT"
fi

banner="🚀 Claude Code on DeepSeek  →  $MAIN_MODEL"
[ -n "$CTX" ] && banner="$banner  |  ctx=$CTX"
echo "$banner  (switch mid-session via /model)"
exec claude "$@"
