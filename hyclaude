#!/usr/bin/env bash
# hyclaude — launch Claude Code on Tencent TokenHub's Anthropic-compatible API.
#
# Tencent TokenHub is a multi-model aggregator — one subscription gives access
# to Hunyuan (HY3), DeepSeek, GLM, Kimi, MiniMax, Qwen, and more.
#
# Endpoint:
#   - Token Plan (recommended): https://api.lkeap.cloud.tencent.com/plan/anthropic
#   - Coding Plan:              https://api.lkeap.cloud.tencent.com/coding/anthropic
#
# Reads HY_API_KEY from the environment first, then falls back to
# ~/.zshrc / ~/.bashrc / ~/.bash_profile / ~/.profile if not already exported.
#
# Quick start (no install needed):
#   chmod +x hyclaude
#   ./hyclaude
#
# Optional — make it globally available:
#   sudo mv hyclaude /usr/local/bin/ && sudo chmod +x /usr/local/bin/hyclaude
#
# Use:
#   hyclaude                  # hy3-preview (Tencent default)
#   hyclaude fast             # hy-mt2-lite (cheap / fast)
#   hyclaude deepseek         # deepseek-v4-pro
#   hyclaude kimi             # kimi-k2.7-code
#   hyclaude glm              # glm-5.2
#   hyclaude minimax          # minimax-m3
#   hyclaude qwen             # qwen3.5-plus
#   hyclaude long             # request max context window
#   hyclaude effort max       # set reasoning effort (low|medium|high|xhigh|max)
#   hyclaude update           # git pull latest from this repo
#   hyclaude --help           # any remaining flag is forwarded to claude
#
# Optional env overrides:
#   HY_MODEL=hy3-preview                      # main model (any model on TokenHub)
#   HY_FLASH_MODEL=hy-mt2-lite                # flash / haiku / subagent tier
#   HY_BASE_URL=https://.../anthropic          # custom Anthropic-compatible base URL
#   HY_CTX=1048576                            # max context tokens
#   HY_OUTPUT=8000                            # cap output tokens
#   HY_EFFORT=max                             # CLAUDE_CODE_EFFORT_LEVEL
#
# Get your API key: https://cloud.tencent.com/product/lkeap

set -euo pipefail

hyclaude_update() {
  local repo="" self_dir
  self_dir="$(cd "$(dirname "$0")" && pwd)"
  if [ -d "$self_dir/.git" ]; then repo="$self_dir"; fi
  if [ -z "$repo" ] && [ -n "${HYCLAUDE_HOME:-}" ]; then repo="$HYCLAUDE_HOME"; fi
  if [ -z "$repo" ] && [ -d "$HOME/github/xxclaude/.git" ]; then repo="$HOME/github/xxclaude"; fi
  if [ -z "$repo" ]; then
    echo "hyclaude: cannot find the xxclaude repo for self-update." >&2
    echo "  Set HYCLAUDE_HOME=/path/to/xxclaude  or  cd into the repo and run ./hyclaude update" >&2
    exit 1
  fi
  echo "hyclaude: pulling latest from $repo ..."
  git -C "$repo" pull && echo "hyclaude: updated." || { echo "hyclaude: git pull failed." >&2; exit 1; }
  exit 0
}

extract_key_from_file() {
  local file="$1"
  [ -f "$file" ] || return 1
  grep -E '^[[:space:]]*(export[[:space:]]+)?HY_API_KEY=' "$file" | tail -n1 | sed -E 's/^[[:space:]]*(export[[:space:]]+)?HY_API_KEY=//' | sed -E 's/^"(.*)"$/\1/; s/^'"'"'(.*)'"'"'$/\1/'
}

if [ $# -gt 0 ] && [ "$1" = "update" ]; then hyclaude_update; fi

API_KEY="${HY_API_KEY:-}"
if [ -z "$API_KEY" ]; then
  for f in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile"; do
    candidate="$(extract_key_from_file "$f" || true)"
    if [ -n "${candidate:-}" ]; then API_KEY="$candidate"; break; fi
  done
fi

if [ -z "$API_KEY" ]; then
  echo "❌ HY_API_KEY not found." >&2
  echo "   Add one line to ~/.zshrc or ~/.bashrc:  export HY_API_KEY=your_api_key" >&2
  echo "   Get your key at: https://cloud.tencent.com/product/lkeap" >&2
  exit 1
fi

BASE_URL="${HY_BASE_URL:-https://api.lkeap.cloud.tencent.com/plan/anthropic}"
PRO_MODEL="${HY_MODEL:-hy3-preview}"
FLASH_MODEL="${HY_FLASH_MODEL:-hy-mt2-lite}"
LONG_CTX=0
EFFORT="${HY_EFFORT:-}"

MAIN_MODEL=""
while [ $# -gt 0 ]; do
  case "$1" in
    # Tier aliases
    max|pro|code)   MAIN_MODEL="$PRO_MODEL"; shift ;;
    fast|flash|lite) MAIN_MODEL="$FLASH_MODEL"; shift ;;
    # Provider aliases
    kimi)           MAIN_MODEL="kimi-k2.7-code"; shift ;;
    kimi-pro|kimi-k2) MAIN_MODEL="kimi-k2.6"; shift ;;
    deepseek)       MAIN_MODEL="deepseek-v4-pro"; shift ;;
    deepseek-flash) MAIN_MODEL="deepseek-v4-flash"; shift ;;
    glm)            MAIN_MODEL="glm-5.2"; shift ;;
    minimax)        MAIN_MODEL="minimax-m3"; shift ;;
    qwen)           MAIN_MODEL="qwen3.5-plus"; shift ;;
    # Context & effort
    long) LONG_CTX=1; shift ;;
    effort)
      case "${2:-}" in
        low|medium|high|xhigh|max) EFFORT="$2"; shift 2 ;;
        *) echo "hyclaude: invalid effort level '${2:-}'. Use: low medium high xhigh max" >&2; exit 1 ;;
      esac
      ;;
    --) shift; break ;;
    *)  break ;;
  esac
done

if [ -z "$MAIN_MODEL" ]; then MAIN_MODEL="$PRO_MODEL"; fi

# Pick a smart alternate for the /model picker.
case "$MAIN_MODEL" in
  "$PRO_MODEL")       OTHER_MODEL="$FLASH_MODEL"; OTHER_DESC="HY MT2 Lite — fast / cheap tier" ;;
  "$FLASH_MODEL")     OTHER_MODEL="$PRO_MODEL";   OTHER_DESC="HY3 Preview — Tencent flagship" ;;
  kimi-k2.7-code)     OTHER_MODEL="kimi-k2.6";    OTHER_DESC="Kimi K2.6 — full reasoning" ;;
  kimi-k2.6)          OTHER_MODEL="kimi-k2.7-code"; OTHER_DESC="Kimi K2.7 Code — code specialist" ;;
  deepseek-v4-pro)    OTHER_MODEL="deepseek-v4-flash"; OTHER_DESC="DeepSeek V4 Flash" ;;
  deepseek-v4-flash)  OTHER_MODEL="deepseek-v4-pro";   OTHER_DESC="DeepSeek V4 Pro" ;;
  *)                  OTHER_MODEL="$PRO_MODEL";   OTHER_DESC="HY3 Preview — Tencent flagship" ;;
esac

unset ANTHROPIC_API_KEY 2>/dev/null || true

export ANTHROPIC_BASE_URL="$BASE_URL"
export ANTHROPIC_AUTH_TOKEN="$API_KEY"
export ANTHROPIC_MODEL="$MAIN_MODEL"
export ANTHROPIC_DEFAULT_OPUS_MODEL="$MAIN_MODEL"
export ANTHROPIC_DEFAULT_SONNET_MODEL="$MAIN_MODEL"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="$FLASH_MODEL"
export CLAUDE_CODE_SUBAGENT_MODEL="$FLASH_MODEL"
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

if [ "$OTHER_MODEL" != "$MAIN_MODEL" ]; then
  export ANTHROPIC_CUSTOM_MODEL_OPTION="$OTHER_MODEL"
  export ANTHROPIC_CUSTOM_MODEL_OPTION_NAME="$OTHER_MODEL"
  export ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION="$OTHER_DESC"
fi

if [ -n "$EFFORT" ]; then export CLAUDE_CODE_EFFORT_LEVEL="$EFFORT"; fi

CTX="${HY_CTX:-}"
if [ -z "$CTX" ] && [ "$LONG_CTX" = "1" ]; then CTX="1048576"; fi
if [ -n "$CTX" ]; then export CLAUDE_CODE_MAX_CONTEXT_TOKENS="$CTX"; export DISABLE_COMPACT=1; fi
if [ -n "${HY_OUTPUT:-}" ]; then export CLAUDE_CODE_MAX_OUTPUT_TOKENS="$HY_OUTPUT"; fi

banner="🚀 Claude Code on TokenHub  →  $MAIN_MODEL  ($BASE_URL)"
[ -n "$CTX" ] && banner="$banner  |  ctx=$CTX"
[ -n "$EFFORT" ] && banner="$banner  |  effort=$EFFORT"
[ "$OTHER_MODEL" != "$MAIN_MODEL" ] && banner="$banner  (switch mid-session via /model)"
echo "$banner"
exec claude "$@"
