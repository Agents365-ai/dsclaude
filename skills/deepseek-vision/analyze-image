#!/usr/bin/env bash
# analyze-image — describe an image via Qwen3.6-Flash for text-only models.
# Usage: analyze-image <input> [focus prompt]
#   <input> can be:
#     - a local file path
#     - an http(s) URL
#     - "latest"    → most recent image in ~/Desktop (handy after Cmd+Shift+4)
#     - "clipboard" → macOS clipboard PNG (handy after Cmd+Ctrl+Shift+4)
# Requires: DASHSCOPE_API_KEY in env. Returns plaintext on stdout.

set -euo pipefail

INPUT="${1:-}"
PROMPT="${2:-Describe this image in detail. Focus on text content, UI elements, code snippets, charts, error messages — anything a coding/agent task might care about.}"

[[ -n "$INPUT" ]] || { echo "analyze-image: missing image path or URL (or 'latest' / 'clipboard')" >&2; exit 1; }
[[ -n "${DASHSCOPE_API_KEY:-}" ]] || { echo "analyze-image: DASHSCOPE_API_KEY not set" >&2; exit 1; }

# Resolve special inputs ('latest', 'clipboard') into a real file path.
case "$INPUT" in
  latest)
    INPUT=$(ls -t \
      "$HOME/Desktop"/*.png "$HOME/Desktop"/*.jpg "$HOME/Desktop"/*.jpeg \
      "$HOME/Desktop"/*.webp "$HOME/Desktop"/*.heic \
      2>/dev/null | head -1 || true)
    [[ -n "$INPUT" && -f "$INPUT" ]] || {
      echo "analyze-image: no image found in ~/Desktop. Take a screenshot (Cmd+Shift+4) and retry, or pass an explicit path." >&2
      exit 1
    }
    echo "analyze-image: using most recent ~/Desktop image: $INPUT" >&2
    ;;
  clipboard)
    INPUT="/tmp/dsvision-clipboard-$$.png"
    if ! osascript >/dev/null 2>&1 <<APPLESCRIPT
try
  set theData to the clipboard as «class PNGf»
  set theFile to open for access (POSIX file "$INPUT") with write permission
  set eof of theFile to 0
  write theData to theFile
  close access theFile
  return "ok"
on error errMsg
  try
    close access theFile
  end try
  error errMsg
end try
APPLESCRIPT
    then
      echo "analyze-image: no PNG image in clipboard. Take a screenshot to clipboard with Cmd+Ctrl+Shift+4 and retry." >&2
      rm -f "$INPUT"
      exit 1
    fi
    echo "analyze-image: using clipboard image (saved to $INPUT)" >&2
    ;;
esac

# URL input → pass through directly (DashScope accepts public http/https URLs).
if [[ "$INPUT" =~ ^https?:// ]]; then
  IMAGE_URL="$INPUT"
else
  [[ -f "$INPUT" ]] || { echo "analyze-image: image not found: $INPUT" >&2; exit 1; }

  # DashScope rejects payloads beyond ~10MB; fail early with a clear message.
  SIZE=$(wc -c < "$INPUT" | tr -d ' ')
  if (( SIZE > 10485760 )); then
    echo "analyze-image: image too large ($SIZE bytes; limit 10485760). Resize and retry." >&2
    exit 1
  fi

  case "$(echo "${INPUT##*.}" | tr 'A-Z' 'a-z')" in
    jpg|jpeg) MIME=image/jpeg ;;
    png)      MIME=image/png  ;;
    webp)     MIME=image/webp ;;
    gif)      MIME=image/gif  ;;
    *)        MIME=$(file --mime-type -b "$INPUT") ;;
  esac

  B64=$(base64 < "$INPUT" | tr -d '\n')
  IMAGE_URL="data:$MIME;base64,$B64"
fi

PAYLOAD=$(jq -n \
  --arg model  "${DSVISION_MODEL:-qwen3.6-flash}" \
  --arg url    "$IMAGE_URL" \
  --arg prompt "$PROMPT" \
  '{
    model: $model,
    messages: [{
      role: "user",
      content: [
        { type: "image_url", image_url: { url: $url } },
        { type: "text", text: $prompt }
      ]
    }]
  }')

BASE_URL="${DSVISION_BASE_URL:-https://dashscope.aliyuncs.com/compatible-mode/v1}"

RESP=$(curl -sS -X POST "$BASE_URL/chat/completions" \
  --connect-timeout 10 \
  --max-time 60 \
  -H "Authorization: Bearer $DASHSCOPE_API_KEY" \
  -H "Content-Type: application/json" \
  --data-raw "$PAYLOAD")

if echo "$RESP" | jq -e '.error' >/dev/null 2>&1; then
  echo "analyze-image: API error" >&2
  echo "$RESP" | jq '.error' >&2
  exit 1
fi

CONTENT=$(echo "$RESP" | jq -r '.choices[0].message.content // empty')

if [[ -z "$CONTENT" ]]; then
  echo "analyze-image: empty response from model" >&2
  echo "$RESP" | jq '.' >&2
  exit 1
fi

echo "$CONTENT"
