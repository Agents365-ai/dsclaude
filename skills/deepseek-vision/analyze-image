#!/usr/bin/env bash
# analyze-image — describe an image via Qwen3.6-Flash for text-only models.
# Usage: analyze-image <input> [focus prompt]
#   <input> can be:
#     - a local file path
#     - an http(s) URL
#     - "clipboard" → macOS clipboard PNG (handy after Cmd+Ctrl+Shift+4)
# Requires: DASHSCOPE_API_KEY in env. Returns plaintext on stdout.

set -euo pipefail

INPUT="${1:-}"
PROMPT="${2:-Describe this image in detail. Focus on text content, UI elements, code snippets, charts, error messages — anything a coding/agent task might care about.}"

[[ -n "$INPUT" ]] || { echo "analyze-image: missing image path, URL, or 'clipboard'" >&2; exit 1; }

# Resolve DASHSCOPE_API_KEY: env first, then shell rc files. Claude Code's
# subprocesses don't always inherit interactive-shell exports, so we look in
# the rc files directly as a fallback.
if [[ -z "${DASHSCOPE_API_KEY:-}" ]]; then
  for rc in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile"; do
    [[ -r "$rc" ]] || continue
    found=$(grep -E '^[[:space:]]*export[[:space:]]+DASHSCOPE_API_KEY=' "$rc" 2>/dev/null \
      | tail -1 \
      | sed -E 's/^[^=]*=//; s/^"(.*)"$/\1/; s/^'\''(.*)'\''$/\1/' \
      || true)
    [[ -n "$found" ]] && { export DASHSCOPE_API_KEY="$found"; break; }
  done
fi
[[ -n "${DASHSCOPE_API_KEY:-}" ]] || {
  echo "analyze-image: DASHSCOPE_API_KEY not set in env or shell rc files (~/.zshrc, ~/.bashrc, ...). Add 'export DASHSCOPE_API_KEY=sk-...' and retry." >&2
  exit 1
}

# Resolve special input 'clipboard' into a real file path. macOS apps put
# images on the pasteboard in different flavors (PNG from screenshots, TIFF
# from Preview, JPEG from some apps, file URLs from Finder Cmd+C). Try them
# all in priority order.
case "$INPUT" in
  clipboard)
    TMP="/tmp/dsvision-clipboard-$$"
    RESULT=$(osascript 2>/dev/null <<APPLESCRIPT
try
  set fileRef to (the clipboard as «class furl»)
  return "FILE:" & POSIX path of fileRef
end try
try
  set pngData to the clipboard as «class PNGf»
  set f to open for access (POSIX file "${TMP}.png") with write permission
  set eof of f to 0
  write pngData to f
  close access f
  return "PNG"
end try
try
  set tiffData to the clipboard as «class TIFF»
  set f to open for access (POSIX file "${TMP}.tiff") with write permission
  set eof of f to 0
  write tiffData to f
  close access f
  return "TIFF"
end try
try
  set jpegData to the clipboard as «class JPEG»
  set f to open for access (POSIX file "${TMP}.jpg") with write permission
  set eof of f to 0
  write jpegData to f
  close access f
  return "JPEG"
end try
return "NONE"
APPLESCRIPT
)
    case "$RESULT" in
      FILE:*)
        INPUT="${RESULT#FILE:}"
        [[ -f "$INPUT" ]] || { echo "analyze-image: clipboard had a file URL but path doesn't exist: $INPUT" >&2; exit 1; }
        echo "analyze-image: using clipboard file: $INPUT" >&2
        ;;
      PNG)
        INPUT="${TMP}.png"
        echo "analyze-image: using clipboard PNG: $INPUT" >&2
        ;;
      TIFF)
        # DashScope doesn't accept TIFF — convert to PNG via macOS-native sips.
        sips -s format png "${TMP}.tiff" --out "${TMP}.png" >/dev/null 2>&1 \
          || { echo "analyze-image: sips failed to convert TIFF→PNG" >&2; rm -f "${TMP}.tiff"; exit 1; }
        rm -f "${TMP}.tiff"
        INPUT="${TMP}.png"
        echo "analyze-image: using clipboard TIFF (converted to PNG): $INPUT" >&2
        ;;
      JPEG)
        INPUT="${TMP}.jpg"
        echo "analyze-image: using clipboard JPEG: $INPUT" >&2
        ;;
      *)
        echo "analyze-image: no image-like data in clipboard (tried PNG/TIFF/JPEG/file-URL). Try one of:" >&2
        echo "  - Cmd+Ctrl+Shift+4 to screenshot to clipboard" >&2
        echo "  - In Finder, Cmd+C an image file" >&2
        echo "  - Open the image in Preview, Edit → Copy" >&2
        rm -f "${TMP}".png "${TMP}".tiff "${TMP}".jpg 2>/dev/null
        exit 1
        ;;
    esac
    ;;
esac

# URL input → pass through directly (DashScope accepts public http/https URLs).
if [[ "$INPUT" =~ ^https?:// ]]; then
  IMAGE_URL="$INPUT"
else
  [[ -f "$INPUT" ]] || { echo "analyze-image: image not found: $INPUT" >&2; exit 1; }

  # DashScope rejects payloads beyond ~10MB; fail early with a clear message.
  SIZE=$(wc -c < "$INPUT" | tr -d ' ')
  if (( SIZE > 10485760 )); then
    echo "analyze-image: image too large ($SIZE bytes; limit 10485760). Resize and retry." >&2
    exit 1
  fi

  case "$(echo "${INPUT##*.}" | tr 'A-Z' 'a-z')" in
    jpg|jpeg) MIME=image/jpeg ;;
    png)      MIME=image/png  ;;
    webp)     MIME=image/webp ;;
    gif)      MIME=image/gif  ;;
    *)        MIME=$(file --mime-type -b "$INPUT") ;;
  esac

  B64=$(base64 < "$INPUT" | tr -d '\n')
  IMAGE_URL="data:$MIME;base64,$B64"
fi

PAYLOAD=$(jq -n \
  --arg model  "${DSVISION_MODEL:-qwen3.6-flash}" \
  --arg url    "$IMAGE_URL" \
  --arg prompt "$PROMPT" \
  '{
    model: $model,
    messages: [{
      role: "user",
      content: [
        { type: "image_url", image_url: { url: $url } },
        { type: "text", text: $prompt }
      ]
    }]
  }')

BASE_URL="${DSVISION_BASE_URL:-https://dashscope.aliyuncs.com/compatible-mode/v1}"

RESP=$(curl -sS -X POST "$BASE_URL/chat/completions" \
  --connect-timeout 10 \
  --max-time 60 \
  -H "Authorization: Bearer $DASHSCOPE_API_KEY" \
  -H "Content-Type: application/json" \
  --data-raw "$PAYLOAD")

if echo "$RESP" | jq -e '.error' >/dev/null 2>&1; then
  echo "analyze-image: API error" >&2
  echo "$RESP" | jq '.error' >&2
  exit 1
fi

CONTENT=$(echo "$RESP" | jq -r '.choices[0].message.content // empty')

if [[ -z "$CONTENT" ]]; then
  echo "analyze-image: empty response from model" >&2
  echo "$RESP" | jq '.' >&2
  exit 1
fi

echo "$CONTENT"
