#!/usr/bin/env bash
# qwclaude — launch Claude Code on local Qwen3.6 models via Ollama.
#
# Uses a built-in Python proxy to translate Anthropic Messages API ↔ Ollama API
# and points Claude Code at it via ANTHROPIC_BASE_URL (same pattern as dsclaude).
# Assumes Ollama is already running at $OLLAMA_HOST and the models are available;
# does not pull or manage models.
#
# Prerequisites:
#   - Ollama running locally with the models already pulled, e.g.:
#       ollama pull qwen3.6-27b         # dense 27B, fast default
#       ollama pull qwen3.6:35b-a3b     # MoE 35B (3B active), thinking mode
#   - Python 3 (pre-installed on macOS and most Linux distributions)
#
# Quick start:
#   chmod +x qwclaude
#   ./qwclaude
#
# Optional — make it globally available:
#   sudo mv qwclaude /usr/local/bin/ && sudo chmod +x /usr/local/bin/qwclaude
#
# Use:
#   qwclaude                  # start on qwen3.6-27b  (dense, fast default)
#   qwclaude think            # start on qwen3.6:35b-a3b (MoE thinking mode)
#   qwclaude -r               # alias for `qwclaude think`
#   qwclaude --help           # any remaining flags forwarded to claude
#
# In-session switch:
#   /model qwen3.6-27b        # switch to dense model
#   /model qwen3.6:35b-a3b    # switch to MoE thinking mode
#
# Env overrides:
#   QWCLAUDE_PORT=9090        # proxy listen port (default 8088)
#   QWCLAUDE_CTX=262144       # context window in tokens (default 262144 = 256K)
#   OLLAMA_HOST=http://...    # Ollama API endpoint (default http://localhost:11434)
#
set -euo pipefail

# --- config ---
DENSE_MODEL="qwen3.6-27b"
MOE_MODEL="qwen3.6:35b-a3b"
OLLAMA_HOST="${OLLAMA_HOST:-http://localhost:11434}"
PORT="${QWCLAUDE_PORT:-8088}"
CTX_TOKENS="${QWCLAUDE_CTX:-262144}"   # 256K context window

# --- model selection ---
MODEL="$DENSE_MODEL"
OTHER_MODEL="$MOE_MODEL"

while [ $# -gt 0 ]; do
  case "$1" in
    think|reasoner|-r)
      MODEL="$MOE_MODEL"
      OTHER_MODEL="$DENSE_MODEL"
      shift
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

# --- check prerequisites ---
if ! python3 -c "import http.server, json, uuid, urllib.request, socket" 2>/dev/null; then
  echo "Python 3 is required but not available." >&2
  exit 1
fi

# --- check port availability ---
if ! python3 -c "
import socket
s = socket.socket()
try:
  s.bind(('127.0.0.1', $PORT))
  s.close()
except OSError:
  print(f'Port $PORT is not available', file=__import__(\"sys\").stderr)
  exit(1)
"; then
  echo "  Set QWCLAUDE_PORT to a different port." >&2
  exit 1
fi

# --- embedded Python proxy ---
PYTHON_PROXY=$(python3 -c "
import base64, zlib
script = '''#!/usr/bin/env python3
"""Anthropic-to-Ollama proxy for Claude Code."""
import json, sys, uuid
from http.server import HTTPServer, BaseHTTPRequestHandler
from urllib.request import Request, urlopen

OLLAMA = sys.argv[1]
PORT = int(sys.argv[2])
NUM_CTX = int(sys.argv[3])


class Handler(BaseHTTPRequestHandler):

    def do_GET(self):
        if self.path == \"/v1/models\":
            self._send_json(200, {\"data\": [{\"id\": \"qwen3.6-27b\", \"object\": \"model\"},
                                          {\"id\": \"qwen3.6:35b-a3b\", \"object\": \"model\"}]})
        else:
            self.send_error(404)

    def do_POST(self):
        if self.path == \"/v1/messages\":
            body = json.loads(self.rfile.read(int(self.headers.get(\"Content-Length\", 0))))
            self._handle_messages(body)
        else:
            self.send_error(404)

    def _handle_messages(self, body):
        stream = body.get(\"stream\", False)
        messages = body.get(\"messages\", [])
        system = body.get(\"system\")

        # prepend system message if present
        if system:
            messages = [{\"role\": \"system\", \"content\": system}] + messages

        # convert tools
        tools = self._convert_tools(body.get(\"tools\"))

        ollama_payload = {
            \"model\": body.get(\"model\", \"qwen3.6-27b\"),
            \"messages\": messages,
            \"stream\": stream,
            \"options\": {\"num_ctx\": NUM_CTX},
        }
        if tools:
            ollama_payload[\"tools\"] = tools
        if \"max_tokens\" in body:
            ollama_payload[\"options\"][\"num_predict\"] = body[\"max_tokens\"]
        if \"temperature\" in body:
            ollama_payload[\"options\"][\"temperature\"] = body[\"temperature\"]
        if \"top_p\" in body:
            ollama_payload[\"options\"][\"top_p\"] = body[\"top_p\"]

        if stream:
            self._handle_stream(ollama_payload)
        else:
            self._handle_non_stream(ollama_payload)

    def _convert_tools(self, tools):
        if not tools:
            return None
        result = []
        for t in tools:
            result.append({
                \"type\": \"function\",
                \"function\": {
                    \"name\": t.get(\"name\", \"\"),
                    \"description\": t.get(\"description\", \"\"),
                    \"parameters\": t.get(\"input_schema\", {}),
                },
            })
        return result

    def _handle_stream(self, payload):
        self.send_response(200)
        self.send_header(\"Content-Type\", \"text/event-stream\")
        self.send_header(\"Cache-Control\", \"no-cache\")
        self.end_headers()

        msg_id = \"msg_\" + uuid.uuid4().hex[:24]

        # message_start
        self._sse({\"type\": \"message_start\", \"message\": {
            \"id\": msg_id, \"type\": \"message\", \"role\": \"assistant\",
            \"content\": [], \"model\": payload[\"model\"],
            \"stop_reason\": None, \"stop_sequence\": None,
            \"usage\": {\"input_tokens\": 0, \"output_tokens\": 0},
        }})
        # content_block_start
        self._sse({\"type\": \"content_block_start\", \"index\": 0,
                   \"content_block\": {\"type\": \"text\", \"text\": \"\"}})

        output_tokens = 0
        try:
            resp = self._ollama_request(payload)
            while True:
                line = resp.readline()
                if not line:
                    break
                line = line.decode().strip()
                if not line:
                    continue
                chunk = json.loads(line)
                delta = chunk.get(\"message\", {}).get(\"content\", \"\")
                if delta:
                    output_tokens += 1
                    self._sse({\"type\": \"content_block_delta\", \"index\": 0,
                               \"delta\": {\"type\": \"text_delta\", \"text\": delta}})
                if chunk.get(\"done\"):
                    self._sse({\"type\": \"content_block_stop\", \"index\": 0})
                    sr = \"max_tokens\" if chunk.get(\"done_reason\") == \"length\" else \"end_turn\"
                    self._sse({\"type\": \"message_delta\",
                               \"delta\": {\"stop_reason\": sr, \"stop_sequence\": None},
                               \"usage\": {\"output_tokens\": chunk.get(\"eval_count\", output_tokens)}})
        except Exception as e:
            self._sse({\"type\": \"error\", \"error\": {\"type\": \"api_error\", \"message\": str(e)}})

        self.wfile.write(b\"data: [DONE]\\\\n\\\\n\")
        self.wfile.flush()

    def _handle_non_stream(self, payload):
        try:
            resp_data = b\"\"
            for chunk in self._ollama_request(payload):
                resp_data += chunk
            resp = json.loads(resp_data)
            content = resp.get(\"message\", {}).get(\"content\", \"\")
            self._send_json(200, {
                \"id\": \"msg_\" + uuid.uuid4().hex[:24],
                \"type\": \"message\", \"role\": \"assistant\",
                \"content\": [{\"type\": \"text\", \"text\": content}],
                \"model\": payload[\"model\"],
                \"stop_reason\": \"end_turn\" if resp.get(\"done_reason\", \"stop\") == \"stop\" else \"max_tokens\",
                \"stop_sequence\": None,
                \"usage\": {
                    \"input_tokens\": resp.get(\"prompt_eval_count\", 0),
                    \"output_tokens\": resp.get(\"eval_count\", 0),
                },
            })
        except Exception as e:
            self._send_json(500, {\"error\": {\"message\": str(e)}})

    def _ollama_request(self, payload):
        req = Request(
            f\"{OLLAMA}/api/chat\",
            data=json.dumps(payload).encode(),
            headers={\"Content-Type\": \"application/json\"},
        )
        return urlopen(req)

    def _sse(self, data):
        self.wfile.write(f\"data: {json.dumps(data)}\\\\n\\\\n\".encode())
        self.wfile.flush()

    def _send_json(self, code, data):
        self.send_response(code)
        self.send_header(\"Content-Type\", \"application/json\")
        self.end_headers()
        self.wfile.write(json.dumps(data).encode())

    def log_message(self, fmt, *args):
        pass


if __name__ == \"__main__\":
    try:
        HTTPServer((\"127.0.0.1\", PORT), Handler).serve_forever()
    except OSError as e:
        if \"Address already in use\" in str(e):
            print(f\"Port {PORT} in use. Set QWCLAUDE_PORT to a different port.\", file=sys.stderr)
            sys.exit(1)
        raise
'''
print(base64.b64encode(zlib.compress(script.encode())).decode())
")

# decode and run the proxy
PYTHON_PROXY_FILE=$(mktemp)
echo "$PYTHON_PROXY" | python3 -c "
import base64, sys, zlib
sys.stdout.buffer.write(zlib.decompress(base64.b64decode(sys.stdin.read().strip())))
" > "$PYTHON_PROXY_FILE"
chmod +x "$PYTHON_PROXY_FILE"

cleanup() {
  [ -n "${PROXY_PID:-}" ] && kill "$PROXY_PID" 2>/dev/null || true
  rm -f "${PYTHON_PROXY_FILE:-}"
}
trap cleanup EXIT INT TERM

python3 "$PYTHON_PROXY_FILE" "$OLLAMA_HOST" "$PORT" "$CTX_TOKENS" &
PROXY_PID=$!

# wait for proxy to be ready
python3 -c "
import urllib.request, sys, time
for _ in range(20):
  try:
    urllib.request.urlopen('http://127.0.0.1:$PORT/v1/models')
    sys.exit(0)
  except:
    time.sleep(0.1)
sys.exit(1)
" || {
  echo "Failed to start the API proxy." >&2
  exit 1
}

# --- set Claude Code env vars (mirrors dsclaude style) ---
export ANTHROPIC_BASE_URL="http://127.0.0.1:$PORT"
export ANTHROPIC_AUTH_TOKEN="ollama-local"   # placeholder — Ollama is local, no auth needed
export API_TIMEOUT_MS="600000"
export ANTHROPIC_MODEL="$MODEL"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="$DENSE_MODEL"
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
export CLAUDE_CODE_MAX_CONTEXT_TOKENS="$CTX_TOKENS"
export DISABLE_COMPACT=1

# expose the other model for in-session switching via /model
export ANTHROPIC_CUSTOM_MODEL_OPTION="$OTHER_MODEL"
export ANTHROPIC_CUSTOM_MODEL_OPTION_NAME="$OTHER_MODEL"
if [ "$OTHER_MODEL" = "$DENSE_MODEL" ]; then
  export ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION="Qwen3.6 dense 27B — fast default"
else
  export ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION="Qwen3.6 MoE 35B (3B active) — complex reasoning"
fi

banner="🚀 Claude Code on Qwen3.6 (Ollama)  →  $MODEL  |  ctx=$CTX_TOKENS"
echo "$banner  (switch mid-session via /model)"

# Don't exec — we need the cleanup trap to kill the proxy when claude exits.
claude "$@"
